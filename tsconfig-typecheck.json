{
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "target": "es2016",
    "moduleResolution": "node16",
    "module": "node16",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "lib": [
      "es2016",
      "dom",
      "webworker"
    ]
  },
  "include": [
    "src/**/*.js"
  ]
}
