{
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "module": "node16",
    "moduleResolution": "node16",
    "strictNullChecks": false,
    "noImplicitAny": false,
    "lib": [
      "ES2020",
      "dom",
      "webworker"
    ]
  },
  "include": [
    "src/**/*.js",
    "*.cjs"
  ]
}
